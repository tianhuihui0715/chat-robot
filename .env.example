APP_NAME=Chat Robot
APP_ENV=dev
LOG_LEVEL=INFO
API_PREFIX=/api/v1

RUNTIME_MODE=mock
INFERENCE_RUNTIME_MODE=mock
INFERENCE_SERVICE_URL=http://localhost:8001
INFERENCE_TIMEOUT_SECONDS=60
HOST_MODEL_ROOT=/root/models
TRACE_STORE_DSN=sqlite:///./data/chat_robot.db

LLM_MODEL_PATH=/root/models/Qwen3-8B
INTENT_MODEL_PATH=/root/models/Qwen2.5-1.5B-Instruct
EMBEDDING_MODEL_PATH=/root/models/bge-m3
RERANKER_MODEL_PATH=/root/models/bge-reranker-v2-m3

LLM_MAX_INPUT_TOKENS=8192
LLM_MAX_NEW_TOKENS=512
GPU_QUEUE_MAXSIZE=100

RAG_TOP_K=4
RAG_SCORE_THRESHOLD=0.1

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chat_robot
POSTGRES_USER=chat_robot
POSTGRES_PASSWORD=chat_robot
POSTGRES_DSN=postgresql+psycopg://chat_robot:chat_robot@postgres:5432/chat_robot

QDRANT_URL=http://qdrant:6333

LANGSMITH_ENABLED=true
LANGSMITH_PROJECT=chat-robot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
